# ============================================================================
# Mifos Loan Summarizer — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# Application
ENVIRONMENT=development

# API Authentication
# Leave empty to disable auth (dev mode only!)
# Set a strong random key for production
API_KEY=

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Primary provider: gemini | groq | cerebras | ollama | hf_inference
LLM_PRIMARY=gemini
LLM_MODEL=gemini-2.5-flash-lite

# Fallback provider (optional, for multi-model consensus)
LLM_FALLBACK=
LLM_FALLBACK_MODEL=

# Provider API Keys (set the key for your chosen provider)
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
HF_API_KEY=
HF_TOKEN=

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ============================================================================
# Fineract Configuration
# ============================================================================
FINERACT_URL=https://demo.mifos.io/fineract-provider
FINERACT_USER=mifos
FINERACT_PASSWORD=password
FINERACT_TENANT=default
FINERACT_SSL_VERIFY=true
FINERACT_CA_BUNDLE=

# ============================================================================
# Pipeline Configuration
# ============================================================================
USE_SEMANTIC_CHUNKING=false
MAX_SEGMENT_TOKENS=200
MAX_INPUT_CHARS=2500
EXTRACTION_MAX_TOKENS=1500
SUMMARY_MAX_TOKENS=600
EXTRACTION_TEMPERATURE=0.1

# Validation thresholds
LEVENSHTEIN_THRESHOLD=0.80
COSINE_THRESHOLD=0.80
CONFIDENCE_THRESHOLD=0.50
MATH_TOLERANCE=0.10

# ============================================================================
# Frontend
# ============================================================================
VITE_API_URL=http://localhost:8000
