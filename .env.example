# ============================================================================
# Mifos Loan Summarizer - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# Application Settings
# ============================================================================
ENVIRONMENT=development
API_KEY=your-secure-api-key-here-min-32-chars

# ============================================================================
# LLM Provider API Keys
# ============================================================================
# Groq (recommended for fast inference)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Hugging Face Inference API
HF_API_KEY=hf_your_huggingface_token_here

# Cerebras (ultra-fast inference)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Ollama (local inference - no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Fineract Configuration
# ============================================================================
FINERACT_URL=https://your-fineract-instance.com
FINERACT_USER=mifos
FINERACT_PASSWORD=password
FINERACT_TENANT=default
FINERACT_SSL_VERIFY=true
# FINERACT_CA_BUNDLE=/path/to/ca-bundle.crt

# ============================================================================
# Pipeline Configuration
# ============================================================================
DEFAULT_PROVIDER=groq
LEVENSHTEIN_THRESHOLD=0.80
COSINE_THRESHOLD=0.80
CONFIDENCE_THRESHOLD=0.60
MATH_TOLERANCE=0.10

# ============================================================================
# Frontend Configuration
# ============================================================================
VITE_API_URL=http://localhost:8000
