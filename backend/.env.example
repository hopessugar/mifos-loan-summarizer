# Mifos Loan Summarizer - Backend Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# AUTHENTICATION (REQUIRED IN PRODUCTION)
# =============================================================================
# API key for authenticating requests to the backend
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Set to 'production' to enforce security checks (SSL verification, API key required)
# Set to 'development' for local development (allows SSL bypass, optional API key)
ENVIRONMENT=development

# =============================================================================
# FINERACT CONNECTION
# =============================================================================
# Mifos X / Apache Fineract instance URL
FINERACT_URL=https://your-fineract-instance.com

# Fineract credentials
FINERACT_USER=mifos
FINERACT_PASSWORD=your-secure-password

# Fineract tenant identifier
FINERACT_TENANT=default

# SSL certificate verification (default: true)
# Only set to false in development with self-signed certificates
# NEVER set to false in production
FINERACT_SSL_VERIFY=true

# Optional: Path to custom CA bundle for self-signed certificates
# FINERACT_CA_BUNDLE=/path/to/ca-cert.pem

# =============================================================================
# LLM PROVIDER API KEYS
# =============================================================================
# HuggingFace API token (for HF Inference API)
HF_TOKEN=

# Groq API key (free tier available)
GROQ_API_KEY=

# Cerebras API key (free tier available)
CEREBRAS_API_KEY=

# =============================================================================
# OLLAMA (LOCAL INFERENCE)
# =============================================================================
# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name
OLLAMA_MODEL=qwen2.5:7b
